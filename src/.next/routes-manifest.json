{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/assistant",
      "regex": "^/assistant(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/assistant(?:/)?$"
    },
    {
      "page": "/breeding",
      "regex": "^/breeding(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/breeding(?:/)?$"
    },
    {
      "page": "/breeds",
      "regex": "^/breeds(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/breeds(?:/)?$"
    },
    {
      "page": "/collar",
      "regex": "^/collar(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/collar(?:/)?$"
    },
    {
      "page": "/consultations",
      "regex": "^/consultations(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/consultations(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/labs",
      "regex": "^/labs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/labs(?:/)?$"
    },
    {
      "page": "/marketplace",
      "regex": "^/marketplace(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/marketplace(?:/)?$"
    },
    {
      "page": "/marketplace/new",
      "regex": "^/marketplace/new(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/marketplace/new(?:/)?$"
    },
    {
      "page": "/nutrition",
      "regex": "^/nutrition(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/nutrition(?:/)?$"
    },
    {
      "page": "/reminders",
      "regex": "^/reminders(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/reminders(?:/)?$"
    },
    {
      "page": "/timeline",
      "regex": "^/timeline(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/timeline(?:/)?$"
    },
    {
      "page": "/vet-report",
      "regex": "^/vet\\-report(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/vet\\-report(?:/)?$"
    }
